# Dreamweaving Garden Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to GitHub.

# ── Discord ────────────────────────────────────────────────────────
# Your bot token from Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# ── Anthropic Vision API ───────────────────────────────────────────
# Used for screenshot parsing (/log flowers, /log vases, etc.)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Admin Dashboard ────────────────────────────────────────────────
# Password to access the Flask flower management dashboard
ADMIN_PASSWORD=change_this_to_something_secure

# ── Database ───────────────────────────────────────────────────────
# Directory where dreamweaving.db is stored.
# On Railway with a volume mounted at /data, leave this as /data.
# Locally, leave blank to use the project folder.
DB_DIR=/data

# ── Logging ────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Flask Admin ────────────────────────────────────────────────────
# Port for the admin dashboard web server
ADMIN_PORT=5000
